<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ToDoBackend</RootNamespace>
    <AssemblyName>ToDo-Backend</AssemblyName>
    <!--
      FIX (B-03 / MEDIUM): Enable XML documentation file generation so that
      Swagger UI can display the XML doc comments authored on controllers,
      DTOs and models.  CS1591 is suppressed to avoid build warnings for any
      public members that do not carry a <summary> tag.
    -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.5.0" />
  </ItemGroup>

</Project>
}